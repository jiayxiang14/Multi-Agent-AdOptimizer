# ============================================
# 多Agent智能广告投放与优化系统 - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入你自己的值
# cp .env.example .env

# ---------- LLM API ----------
# OpenAI (推荐，用于LangGraph Agent)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# MiniMax (可选，国内模型)
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_GROUP_ID=your-group-id

# ---------- 广告平台 API ----------
# Google Ads (模拟模式下可留空)
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-token
GOOGLE_ADS_CLIENT_ID=your-client-id
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_CUSTOMER_ID=your-customer-id

# Meta Marketing API (模拟模式下可留空)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-meta-access-token
META_AD_ACCOUNT_ID=act_your-account-id

# ---------- 数据存储 ----------
# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=ad_optimizer

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- 系统配置 ----------
# 运行模式: mock(模拟) / live(真实API)
RUN_MODE=mock

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# Streamlit 仪表板
DASHBOARD_PORT=8501
